# Copie ce fichier en .env et remplis les valeurs.
# Le vrai .env n'est PAS versionné (voir .gitignore).

# Backend de base : "mysql" (prod) ou "sqlite" (tests)
DB_BACKEND=mysql

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=ton_mot_de_passe_mysql
MYSQL_DB=kotcha_races

# --- SQLite (si DB_BACKEND=sqlite) ---
RACES_DB_PATH=races.db

# --- Paramètres du connecteur RunSignup (optionnels) ---
# RUNSIGNUP_COUNTRY=US        # pays ciblé : US, CA, FR, AU, GB...
# RUNSIGNUP_STATE=CA          # (si US) un état, ou "ALL" pour tous
# RUNSIGNUP_REGIONS=ON,QC,BC  # (hors US) régions précises, sinon tout le pays
# RUNSIGNUP_START=2026-06-07  # par défaut : aujourd'hui
# RUNSIGNUP_END=2026-09-05    # par défaut : +90 jours
# RUNSIGNUP_CACHE_DIR=cache   # mode hors-ligne depuis des fichiers JSON

# --- Connecteur Race Roster (optionnel, US + Canada) ---
# API OAuth2 : identifiants à créer sur
# https://raceroster.com/dashboard/account/api-settings
# Le connecteur ne s'active QUE si RACEROSTER_CLIENT_ID est renseigné.
# RACEROSTER_CLIENT_ID=
# RACEROSTER_CLIENT_SECRET=
# RACEROSTER_USERNAME=
# RACEROSTER_PASSWORD=

# --- Connecteur Athlinks (optionnel, couverture internationale) ---
# Clé API à créer sur https://athlinks.3scale.net/signup
# Le connecteur ne s'active QUE si ATHLINKS_API_KEY est renseigné.
# ATHLINKS_API_KEY=
# ATHLINKS_AUTH_PARAM=apikey   # ou "user_key" selon ton compte 3scale
# ATHLINKS_COUNTRY=US          # code pays (voir api.athlinks.com/enums/Countries)
# ATHLINKS_TERM=               # terme de recherche optionnel
